# Spec Cockpit — server config. Copy to `.env` and fill in.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Default is the most capable model. For snappier live demos you can
# drop to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional. low | medium | high. Lower = faster turns. Default medium.
ANTHROPIC_EFFORT=medium

# Optional. The frontend dev server proxies /api to this port.
PORT=8787
